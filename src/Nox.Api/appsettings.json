{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Orleans": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Nox": {
    "Database": {
      "ConnectionString": ""
    },
    "Orleans": {
      "ClusterId": "nox-cluster",
      "ServiceId": "nox",
      "PostgresConnectionString": ""
    },
    "Redis": {
      "ConnectionString": ""
    },
    "Qdrant": {
      "Host": "localhost",
      "Port": "6334",
      "CollectionName": "nox_project_memory",
      "ApiKey": ""
    },
    "Llm": {
      "DefaultModel": "Claude4",
      "Providers": {
        "Anthropic": { "ApiKey": "" },
        "OpenAI":    { "ApiKey": "" },
        "Google":    { "ApiKey": "" }
      }
    },
    "Agent": {
      "GlobalMaxSubAgents": 10,
      "DefaultTokenBudget": 128000
    },
    "Auth": {
      "Authority": "http://localhost:8080/realms/nox",
      "Audience": "nox-api",
      "RequireHttpsMetadata": false
    },
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:5050",
        "https://localhost:5051"
      ]
    }
  }
}
