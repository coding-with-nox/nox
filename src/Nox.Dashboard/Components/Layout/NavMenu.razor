@using Nox.Domain.Hitl
@using Nox.Domain.Skills
@using Nox.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject NoxDbContext Db
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="">⚡ Nox</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                🏠 Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3 mt-2">
            <small class="text-muted px-1">ORCHESTRATION</small>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="flows">
                🔀 Flow Designer
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="agents">
                🤖 Agent Monitor
            </NavLink>
        </div>

        <div class="nav-item px-3 mt-2">
            <small class="text-muted px-1">HUMAN-IN-THE-LOOP</small>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link d-flex justify-content-between align-items-center" href="hitl">
                <span>🧑‍💼 Review Queue</span>
                @if (_pendingCheckpoints > 0)
                {
                    <span class="badge bg-danger ms-1">@_pendingCheckpoints</span>
                }
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link d-flex justify-content-between align-items-center" href="skills">
                <span>⚡ Skill Approval</span>
                @if (_pendingSkills > 0)
                {
                    <span class="badge bg-warning text-dark ms-1">@_pendingSkills</span>
                }
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="mcp">
                🔌 MCP Servers
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private int _pendingCheckpoints;
    private int _pendingSkills;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadCounts();
        _timer = new Timer(_ => InvokeAsync(async () =>
        {
            await LoadCounts();
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));
    }

    private async Task LoadCounts()
    {
        try
        {
            _pendingCheckpoints = await Db.HitlCheckpoints.CountAsync(h => h.Status == CheckpointStatus.Pending);
            _pendingSkills = await Db.Skills.CountAsync(s => s.Status == SkillStatus.PendingApproval);
        }
        catch { /* DB might not be ready yet */ }
    }

    public void Dispose() => _timer?.Dispose();
}
