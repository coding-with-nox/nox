@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="page @(IsLoginPage ? "page-login" : null)">
    @if (!IsLoginPage)
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main class="@(IsLoginPage ? "login-main" : null)">
        @if (!IsLoginPage)
        {
            <div class="top-row px-3 py-1 d-flex justify-content-end align-items-center gap-2">
                <AuthorizeView>
                    <Authorized>
                        <details class="user-menu">
                            <summary class="user-menu-trigger" aria-label="Menu utente">
                                <span class="user-menu-avatar" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10c-2.029 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                                    </svg>
                                </span>
                                <span class="user-menu-name">@context.User.Identity?.Name</span>
                            </summary>

                            <div class="user-menu-dropdown">
                                <button class="user-menu-action"
                                        type="button"
                                        @onclick='() => Nav.NavigateTo("/logout", forceLoad: true)'>
                                    Esci
                                </button>
                            </div>
                        </details>
                    </Authorized>
                </AuthorizeView>
            </div>
        }

        <article class="content @(IsLoginPage ? "content-login" : null)">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Si è verificato un errore.
    <a href="." class="reload">Ricarica</a>
    <span class="dismiss">✕</span>
</div>

@code {
    private bool IsLoginPage =>
        Nav.ToBaseRelativePath(Nav.Uri).StartsWith("login", StringComparison.OrdinalIgnoreCase);
}
