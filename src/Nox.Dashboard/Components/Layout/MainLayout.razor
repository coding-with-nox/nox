@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="page @(IsLoginPage ? "page-login" : null)">
    @if (!IsLoginPage)
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main class="@(IsLoginPage ? "login-main" : null)">
        @if (!IsLoginPage)
        {
            <div class="top-row px-3 py-1 d-flex justify-content-end align-items-center gap-2"
                 style="background:#f8fafc;border-bottom:1px solid #e2e8f0;font-size:.82rem;min-height:36px;">
                <AuthorizeView>
                    <Authorized>
                        <span class="text-muted">
                            <span style="opacity:.5">✦</span>
                            @context.User.Identity?.Name
                        </span>
                        @foreach (var role in new[]{"nox-admin","nox-manager","nox-viewer"}
                            .Where(r => context.User.IsInRole(r)))
                        {
                            <span class="badge bg-secondary" style="font-size:.7rem;">@role</span>
                        }
                        <button class="btn btn-outline-secondary btn-sm py-0 px-2"
                                style="font-size:.78rem;"
                                @onclick='() => Nav.NavigateTo("/logout", forceLoad: true)'>
                            Esci
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>
        }

        <article class="content @(IsLoginPage ? "content-login" : null)">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Si è verificato un errore.
    <a href="." class="reload">Ricarica</a>
    <span class="dismiss">✕</span>
</div>

@code {
    private bool IsLoginPage =>
        Nav.ToBaseRelativePath(Nav.Uri).StartsWith("login", StringComparison.OrdinalIgnoreCase);
}
