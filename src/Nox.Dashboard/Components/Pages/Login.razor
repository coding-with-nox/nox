@page "/login"
@attribute [AllowAnonymous]
@inject NavigationManager Nav

<PageTitle>Accedi — Nox Orchestration</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-logo">
            <img src="nox-mark.svg" alt="Nox" width="56" height="56" />
        </div>
        <h1 class="login-title">Nox Orchestration</h1>
        <p class="login-subtitle">Accedi con il tuo account per continuare</p>

        @if (_loading)
        {
            <div class="login-spinner">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Redirect in corso…</span>
                </div>
                <span class="login-spinner-label">Connessione a Keycloak…</span>
            </div>
        }
        else
        {
            <button class="btn btn-primary login-btn" @onclick="SignIn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                     viewBox="0 0 16 16" class="me-2">
                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                </svg>
                Accedi
            </button>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }

    private bool _loading;

    private void SignIn()
    {
        _loading = true;
        var target = string.IsNullOrEmpty(ReturnUrl)
            ? "/auth/login"
            : $"/auth/login?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
        Nav.NavigateTo(target, forceLoad: true);
    }
}

<style>
    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-base, #f5f6fa);
    }

    .login-card {
        background: var(--surface, #fff);
        border: 1px solid var(--border, #e2e8f0);
        border-radius: 16px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 380px;
        text-align: center;
        box-shadow: 0 4px 24px rgba(0,0,0,.08);
    }

    .login-logo {
        margin-bottom: 1.25rem;
    }

    .login-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: .375rem;
        color: var(--text-primary, #1a202c);
    }

    .login-subtitle {
        font-size: .9rem;
        color: var(--text-muted, #718096);
        margin-bottom: 1.75rem;
    }

    .login-btn {
        width: 100%;
        padding: .625rem 1rem;
        font-size: .95rem;
        font-weight: 600;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-spinner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .75rem;
    }

    .login-spinner-label {
        font-size: .875rem;
        color: var(--text-muted, #718096);
    }
</style>
