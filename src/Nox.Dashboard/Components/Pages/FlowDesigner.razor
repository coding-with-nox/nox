@page "/flows"
@using Nox.Domain
@using Nox.Domain.Flows
@using Nox.Domain.Agents
@using Nox.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inherits NoxPageBase
@inject IDbContextFactory<NoxDbContext> DbFactory
@inject IFlowEngine FlowEngine
@inject NavigationManager Navigation

<PageTitle>@Loc["flows.title"] — Nox</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>⇄ @Loc["flows.title"]</h2>
        <button class="btn btn-primary" @onclick="() => _showCreateModal = true">@Loc["flows.new"]</button>
    </div>

    @if (!string.IsNullOrEmpty(_runError))
    {
        <div class="alert alert-danger d-flex justify-content-between align-items-center">
            <span>@_runError</span>
            <button class="btn-close btn-sm" @onclick="() => _runError = string.Empty"></button>
        </div>
    }

    @if (_flows.Count == 0)
    {
        <div class="alert alert-secondary">@Loc["flows.no_flows"]</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var flow in _flows)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between">
                            <strong>@flow.Name</strong>
                            <span class="badge bg-@GetFlowStatusColor(flow.Status)">@flow.Status</span>
                        </div>
                        <div class="card-body">
                            <p class="text-muted small">@flow.Description</p>
                            <div class="small">
                                <span class="me-3">🗂 @flow.Graph.Nodes.Count @Loc["flows.nodes"]</span>
                                <span>🔗 @flow.Graph.Edges.Count @Loc["flows.edges"]</span>
                            </div>
                            <div class="small text-muted mt-1">v@flow.Version · Updated @flow.UpdatedAt.ToString("dd/MM HH:mm")</div>
                        </div>
                        <div class="card-footer d-flex gap-2">
                            <button class="btn btn-outline-primary btn-sm" @onclick="() => ViewFlow(flow)">@Loc["flows.view"]</button>
                            <button class="btn btn-success btn-sm" @onclick="() => OpenRunModal(flow.Id)">@Loc["flows.run"]</button>
                            <button class="btn btn-outline-secondary btn-sm ms-auto" @onclick="() => OpenEditFlow(flow)">@Loc["edit"]</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (_selectedFlow is not null)
    {
        <div class="mt-4">
            <h4>Flow: @_selectedFlow.Name</h4>
            <div class="card">
                <div class="card-body" style="overflow-x: auto;">
                    <!-- Simple text-based graph visualization -->
                    <table class="table table-sm">
                        <thead><tr><th>@Loc["flows.node"]</th><th>@Loc["type"]</th><th>@Loc["flows.outgoing"]</th></tr></thead>
                        <tbody>
                            @foreach (var node in _selectedFlow.Graph.Nodes)
                            {
                                <tr>
                                    <td><code>@node.Id</code> — @node.Label</td>
                                    <td><span class="badge bg-secondary">@node.NodeType</span></td>
                                    <td>
                                        @foreach (var edge in _selectedFlow.Graph.GetOutgoingEdges(node.Id))
                                        {
                                            <span class="badge bg-light text-dark me-1">
                                                → @edge.ToNodeId
                                                @if (edge.Condition is not null)
                                                {
                                                    <span class="text-muted"> [@edge.Condition]</span>
                                                }
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (_runs.Count > 0)
    {
        <h4 class="mt-4">@Loc["flows.recent"]</h4>
        <table class="table table-sm">
            <thead><tr><th>@Loc["flows.run_id"]</th><th>@Loc["home.flow"]</th><th>@Loc["status"]</th><th>@Loc["flows.started"]</th><th>@Loc["flows.completed"]</th></tr></thead>
            <tbody>
                @foreach (var run in _runs.Take(20))
                {
                    <tr>
                        <td><code>@run.Id.ToString()[..8]…</code></td>
                        <td>@(_flows.FirstOrDefault(f => f.Id == run.FlowId)?.Name ?? run.FlowId.ToString())</td>
                        <td><span class="badge bg-@GetRunStatusColor(run.Status)">@run.Status</span></td>
                        <td>@run.StartedAt.ToString("dd/MM HH:mm")</td>
                        <td>@(run.CompletedAt?.ToString("HH:mm:ss") ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showCreateModal)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Loc["flows.new_title"]</h5>
                    <button class="btn-close" @onclick="() => _showCreateModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">@Loc["name"] *</label>
                        <input class="form-control" @bind="_newFlowName" placeholder="es. Analisi Codice Backend" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Loc["flows.desc"]</label>
                        <textarea class="form-control" rows="2" @bind="_newFlowDesc"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Loc["flows.template_agent"]</label>
                        <select class="form-select" @bind="_newFlowTemplateId">
                            <option value="@Guid.Empty">— @Loc["flows.no_template"] —</option>
                            @foreach (var t in _templates)
                            {
                                <option value="@t.Id">@t.Name (@t.Role)</option>
                            }
                        </select>
                        <div class="form-text">@Loc["flows.template_hint"]</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showCreateModal = false">@Loc["cancel"]</button>
                    <button class="btn btn-primary" @onclick="CreateFlow">@Loc["flows.create"]</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@if (_editingFlow is not null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Loc["edit"]: @_editingFlow.Name</h5>
                    <button class="btn-close" @onclick="() => _editingFlow = null"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">@Loc["name"] *</label>
                        <input class="form-control" @bind="_editFlowName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Loc["flows.desc"]</label>
                        <textarea class="form-control" rows="2" @bind="_editFlowDesc"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Loc["status"]</label>
                        <select class="form-select" @bind="_editFlowStatus">
                            @foreach (var s in Enum.GetValues<FlowStatus>())
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _editingFlow = null">@Loc["cancel"]</button>
                    <button class="btn btn-primary" @onclick="SaveEditFlow">@Loc["save"]</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@if (_showRunModal)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">▶ Avvia Flow</h5>
                    <button class="btn-close" @onclick="() => _showRunModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info small mb-3">
                        Le variabili GitHub vengono passate come contesto a tutti gli agenti del flow.
                        Il PAT non viene loggato ma è visibile in chiaro nel database.
                    </div>

                    <h6 class="fw-semibold mb-2">Configurazione GitHub</h6>
                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">Repository <span class="text-muted small">(owner/repo)</span></label>
                            <input class="form-control" @bind="_runGithubRepo" placeholder="es. myorg/my-project" />
                        </div>
                        <div class="col">
                            <label class="form-label">Personal Access Token</label>
                            <input type="password" class="form-control" @bind="_runGithubPat" placeholder="ghp_..." />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">Branch di lavoro</label>
                            <input class="form-control" @bind="_runGithubBranch" placeholder="es. ai/feature-123" />
                            <div class="form-text">Il branch verrà creato dagli agenti se non esiste.</div>
                        </div>
                        <div class="col">
                            <label class="form-label">Branch base</label>
                            <input class="form-control" @bind="_runGithubBaseBranch" placeholder="main" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Numero Issue GitHub <span class="text-muted small">(opzionale)</span></label>
                        <input type="number" class="form-control w-auto" @bind="_runGithubIssueNumber"
                               @bind:after="AutoFillBranch" min="1" placeholder="42" />
                    </div>

                    <details class="mt-3">
                        <summary class="small text-muted">Variabili aggiuntive (JSON)</summary>
                        <textarea class="form-control font-monospace mt-2" rows="3"
                                  @bind="_runExtraVariables"
                                  placeholder="{&quot;my_key&quot;: &quot;my_value&quot;}"></textarea>
                    </details>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showRunModal = false">@Loc["cancel"]</button>
                    <button class="btn btn-success" @onclick="ConfirmStartFlow">▶ Avvia</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@code {
    private List<Flow> _flows = [];
    private List<FlowRun> _runs = [];
    private List<AgentTemplate> _templates = [];
    private Flow? _selectedFlow;
    private bool _showCreateModal;
    private string _newFlowName = string.Empty;
    private string _newFlowDesc = string.Empty;
    private Guid _newFlowTemplateId = Guid.Empty;
    private string _runError = string.Empty;

    // Run modal state
    private bool _showRunModal;
    private Guid _pendingRunFlowId;
    private string _runGithubRepo        = string.Empty;
    private string _runGithubPat         = string.Empty;
    private string _runGithubBranch      = string.Empty;
    private string _runGithubBaseBranch  = "main";
    private int?   _runGithubIssueNumber;
    private string _runExtraVariables    = string.Empty;

    // Edit state
    private Flow? _editingFlow;
    private string _editFlowName = string.Empty;
    private string _editFlowDesc = string.Empty;
    private FlowStatus _editFlowStatus;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _flows = await db.Flows.OrderByDescending(f => f.UpdatedAt).ToListAsync();
        _runs = await db.FlowRuns.OrderByDescending(r => r.StartedAt).Take(50).ToListAsync();
        _templates = await db.AgentTemplates.OrderBy(t => t.Name).ToListAsync();
    }

    private void ViewFlow(Flow flow)
    {
        _selectedFlow = _selectedFlow?.Id == flow.Id ? null : flow;
    }

    private void AutoFillBranch()
    {
        if (!string.IsNullOrWhiteSpace(_runGithubBranch)) return;
        _runGithubBranch = _runGithubIssueNumber.HasValue
            ? $"ai/issue-{_runGithubIssueNumber}"
            : $"ai/flow-{DateTimeOffset.UtcNow:yyyyMMdd-HHmm}";
    }

    private void OpenRunModal(Guid flowId)
    {
        _pendingRunFlowId = flowId;
        _runError = string.Empty;
        _showRunModal = true;
    }

    private async Task ConfirmStartFlow()
    {
        _runError = string.Empty;
        _showRunModal = false;
        try
        {
            var variables = new System.Text.Json.Nodes.JsonObject();

            if (!string.IsNullOrWhiteSpace(_runGithubRepo))
                variables["github_repo"] = _runGithubRepo.Trim();
            if (!string.IsNullOrWhiteSpace(_runGithubPat))
                variables["github_pat"] = _runGithubPat.Trim();
            if (!string.IsNullOrWhiteSpace(_runGithubBranch))
                variables["github_branch"] = _runGithubBranch.Trim();
            if (!string.IsNullOrWhiteSpace(_runGithubBaseBranch))
                variables["github_base_branch"] = _runGithubBaseBranch.Trim();
            if (_runGithubIssueNumber.HasValue)
                variables["github_issue_number"] = _runGithubIssueNumber.Value;

            // Merge extra variables if provided
            if (!string.IsNullOrWhiteSpace(_runExtraVariables))
            {
                try
                {
                    var extra = System.Text.Json.Nodes.JsonNode.Parse(_runExtraVariables)?.AsObject();
                    if (extra is not null)
                        foreach (var kv in extra)
                            variables[kv.Key] = kv.Value?.DeepClone();
                }
                catch { /* ignore malformed JSON */ }
            }

            await FlowEngine.StartAsync(_pendingRunFlowId, variables);
            await LoadData();
        }
        catch (Exception ex)
        {
            _runError = ex.Message.Contains("Start node")
                ? "Il flow non ha un nodo Start. Visualizza il grafo e verifica la struttura."
                : $"Errore avvio: {ex.Message}";
        }
    }

    private async Task CreateFlow()
    {
        if (string.IsNullOrWhiteSpace(_newFlowName)) return;

        // Scaffold a minimal valid graph
        var graph = new FlowGraph();
        if (_newFlowTemplateId != Guid.Empty)
        {
            var tpl = _templates.FirstOrDefault(t => t.Id == _newFlowTemplateId);
            graph.Nodes.Add(new FlowNode { Id = "start-1",  NodeType = NodeType.Start,     Label = "Start", Position = new(100, 200) });
            graph.Nodes.Add(new FlowNode { Id = "task-1",   NodeType = NodeType.AgentTask,  Label = tpl?.Name ?? "Agent Task", AgentTemplateId = _newFlowTemplateId, Position = new(300, 200) });
            graph.Nodes.Add(new FlowNode { Id = "end-1",    NodeType = NodeType.End,        Label = "End",   Position = new(500, 200) });
            graph.Edges.Add(new FlowEdge { FromNodeId = "start-1", ToNodeId = "task-1" });
            graph.Edges.Add(new FlowEdge { FromNodeId = "task-1",  ToNodeId = "end-1"  });
        }
        else
        {
            graph.Nodes.Add(new FlowNode { Id = "start-1", NodeType = NodeType.Start, Label = "Start", Position = new(100, 200) });
            graph.Nodes.Add(new FlowNode { Id = "end-1",   NodeType = NodeType.End,   Label = "End",   Position = new(300, 200) });
            graph.Edges.Add(new FlowEdge { FromNodeId = "start-1", ToNodeId = "end-1" });
        }

        var flow = new Flow
        {
            Name = _newFlowName,
            Description = string.IsNullOrWhiteSpace(_newFlowDesc) ? null : _newFlowDesc,
            ProjectId = Guid.Parse("00000000-0000-0000-0000-000000000001"),
            CreatedBy = "HITL User",
            Graph = graph,
            Status = FlowStatus.Active,
        };
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Flows.Add(flow);
        await db.SaveChangesAsync();

        _showCreateModal = false;
        _newFlowName = string.Empty;
        _newFlowDesc = string.Empty;
        _newFlowTemplateId = Guid.Empty;
        await LoadData();
    }

    private void OpenEditFlow(Flow flow)
    {
        _editingFlow = flow;
        _editFlowName = flow.Name;
        _editFlowDesc = flow.Description ?? string.Empty;
        _editFlowStatus = flow.Status;
    }

    private async Task SaveEditFlow()
    {
        if (_editingFlow is null || string.IsNullOrWhiteSpace(_editFlowName)) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.Flows.FindAsync(_editingFlow.Id);
        if (existing is not null)
        {
            existing.Name = _editFlowName;
            existing.Description = string.IsNullOrWhiteSpace(_editFlowDesc) ? null : _editFlowDesc;
            existing.Status = _editFlowStatus;
            await db.SaveChangesAsync();
        }
        _editingFlow = null;
        await LoadData();
    }

    private static string GetFlowStatusColor(FlowStatus s) => s switch
    {
        FlowStatus.Active => "success",
        FlowStatus.Draft => "secondary",
        FlowStatus.Paused => "warning",
        FlowStatus.Completed => "info",
        FlowStatus.Failed => "danger",
        _ => "secondary"
    };

    private static string GetRunStatusColor(FlowRunStatus s) => s switch
    {
        FlowRunStatus.Running => "primary",
        FlowRunStatus.Paused => "warning",
        FlowRunStatus.Completed => "success",
        FlowRunStatus.Failed => "danger",
        FlowRunStatus.Cancelled => "secondary",
        _ => "secondary"
    };
}
