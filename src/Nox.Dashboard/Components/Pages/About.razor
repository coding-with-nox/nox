@page "/about"
@inherits NoxPageBase

<PageTitle>@Loc["nav.about"] - Nox</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <h2 class="mb-0">About Nox</h2>
            <small class="text-muted">@Loc["about.subtitle"]</small>
        </div>
        <a class="btn btn-outline-secondary btn-sm"
           href="https://docs.docker.com/compose/"
           target="_blank"
           rel="noopener noreferrer">@Loc["about.compose_docs"]</a>
    </div>

    <div class="card mb-4">
        <div class="card-body py-2 d-flex gap-4 flex-wrap">
            <span class="small text-muted">@Loc["about.platforms"]: <strong>@Platforms.Count</strong></span>
            <span class="small text-muted">@Loc["about.compose_sources"]: <code>docker-compose.yml</code>, <code>infrastructure/docker-compose.yml</code></span>
        </div>
    </div>

    <div class="row g-3">
        @foreach (var platform in Platforms)
        {
            <div class="col-12 col-xl-6">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong>@platform.Name</strong>
                        <span class="badge bg-light">@platform.ComposeService</span>
                    </div>
                    <div class="card-body">
                        <p class="small text-muted mb-3">@(Loc.Lang == "it" ? platform.DescriptionIt : platform.DescriptionEn)</p>

                        <div class="small mb-2">
                            <span class="text-muted">@Loc["about.role"]:</span>
                            <strong>@(Loc.Lang == "it" ? platform.RoleIt : platform.RoleEn)</strong>
                        </div>

                        <div class="small mb-3">
                            <span class="text-muted">@Loc["about.ports"]:</span>
                            <code>@platform.Ports</code>
                        </div>

                        <div class="d-flex gap-2 flex-wrap">
                            <a class="btn btn-outline-primary btn-sm"
                               href="@platform.OfficialUrl"
                               target="_blank"
                               rel="noopener noreferrer">@Loc["about.official_site"]</a>

                            @if (!string.IsNullOrWhiteSpace(platform.LocalUrl))
                            {
                                <a class="btn btn-outline-secondary btn-sm"
                                   href="@platform.LocalUrl"
                                   target="_blank"
                                   rel="noopener noreferrer">@Loc["about.local_access"]</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

