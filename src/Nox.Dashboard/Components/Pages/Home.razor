@page "/"
@using Microsoft.EntityFrameworkCore
@using Nox.Infrastructure.Persistence
@inherits NoxPageBase
@inject IDbContextFactory<NoxDbContext> DbFactory
@inject IHitlQueue HitlQueue

<PageTitle>@Loc["nav.dashboard"] — Nox</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">⚡ @Loc["home.title"]</h2>
            <small class="text-muted">@Loc["home.subtitle"]</small>
        </div>
        <button class="btn btn-outline-secondary btn-sm" @onclick="Refresh">@Loc["refresh"]</button>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card text-center border-primary">
                <div class="card-body py-3">
                    <div class="display-6 fw-bold text-primary">@_pendingCheckpoints</div>
                    <div class="small text-muted">@Loc["home.pending"]</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-success">
                <div class="card-body py-3">
                    <div class="display-6 fw-bold text-success">@_activeFlowRuns</div>
                    <div class="small text-muted">@Loc["home.active_flows"]</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-info">
                <div class="card-body py-3">
                    <div class="display-6 fw-bold text-info">@_runningAgents</div>
                    <div class="small text-muted">@Loc["home.running_agents"]</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-warning">
                <div class="card-body py-3">
                    <div class="display-6 fw-bold text-warning">@_pendingSkills</div>
                    <div class="small text-muted">@Loc["home.skills_wait"]</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- Recent Flow Runs -->
        <div class="col-12 col-lg-7">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>@Loc["home.recent_runs"]</strong>
                    <a href="flows" class="btn btn-outline-primary btn-sm">@Loc["view_all"]</a>
                </div>
                <div class="card-body p-0">
                    @if (_recentRuns.Count == 0)
                    {
                        <p class="text-muted p-3 mb-0">@Loc["home.no_runs"]</p>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>@Loc["home.run"]</th>
                                    <th>@Loc["home.flow"]</th>
                                    <th>@Loc["status"]</th>
                                    <th>@Loc["home.started"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var run in _recentRuns)
                                {
                                    <tr>
                                        <td><code class="small">@run.Id.ToString()[..8]…</code></td>
                                        <td class="small">@(_flows.TryGetValue(run.FlowId, out var fn) ? fn : run.FlowId.ToString()[..8])</td>
                                        <td><span class="badge bg-@GetRunColor(run.Status)">@run.Status</span></td>
                                        <td class="small text-muted">@run.StartedAt.ToString("dd/MM HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <!-- Pending HITL -->
        <div class="col-12 col-lg-5">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>◉ @Loc["home.pending_card"]</strong>
                    <a href="hitl" class="btn btn-outline-success btn-sm">@Loc["home.pending_card"] →</a>
                </div>
                <div class="card-body p-0">
                    @if (_pendingCheckpointList.Count == 0)
                    {
                        <p class="text-muted p-3 mb-0">@Loc["home.all_clear"]</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var cp in _pendingCheckpointList.Take(5))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center py-2">
                                    <div>
                                        <span class="badge bg-secondary me-1">@cp.Type</span>
                                        <span class="small">@cp.Title</span>
                                    </div>
                                    @if (cp.ExpiresAt.HasValue)
                                    {
                                        <small class="text-muted">@cp.ExpiresAt.Value.ToString("HH:mm")</small>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- System info -->
    <div class="row g-3 mt-1">
        <div class="col-12">
            <div class="card">
                <div class="card-body py-2 d-flex gap-4 flex-wrap">
                    <span class="small text-muted">@Loc["home.flows_def"]: <strong>@_totalFlows</strong></span>
                    <span class="small text-muted">@Loc["home.templates"]: <strong>@_totalTemplates</strong></span>
                    <span class="small text-muted">@Loc["home.active_skills"]: <strong>@_activeSkills</strong></span>
                    <span class="small text-muted">@Loc["home.mcp_servers"]: <strong>@_mcpServers</strong></span>
                    <span class="small text-muted ms-auto">@Loc["home.last_refresh"]: <strong>@_lastRefresh.ToString("HH:mm:ss")</strong></span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int _pendingCheckpoints;
    private int _activeFlowRuns;
    private int _runningAgents;
    private int _pendingSkills;
    private int _totalFlows;
    private int _totalTemplates;
    private int _activeSkills;
    private int _mcpServers;
    private List<Nox.Domain.Flows.FlowRun> _recentRuns = [];
    private List<HitlCheckpoint> _pendingCheckpointList = [];
    private Dictionary<Guid, string> _flows = new();
    private DateTimeOffset _lastRefresh;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        await Refresh();
    }

    private async Task Refresh()
    {
        _pendingCheckpointList = await HitlQueue.GetAllPendingAsync(take: 10);
        _pendingCheckpoints = _pendingCheckpointList.Count;

        await using var db = await DbFactory.CreateDbContextAsync();

        _activeFlowRuns = await db.FlowRuns.CountAsync(r =>
            r.Status == FlowRunStatus.Running || r.Status == FlowRunStatus.Paused);

        _runningAgents = await db.Agents.CountAsync(a =>
            a.Status == AgentStatus.Running || a.Status == AgentStatus.WaitingForHitl);

        _pendingSkills = await db.Skills.CountAsync(s => s.Status == SkillStatus.PendingApproval);

        _totalFlows = await db.Flows.CountAsync();
        _totalTemplates = await db.AgentTemplates.CountAsync();
        _activeSkills = await db.Skills.CountAsync(s => s.Status == SkillStatus.Active);
        _mcpServers = await db.McpServers.CountAsync(s => s.Status == McpServerStatus.Active);

        _recentRuns = await db.FlowRuns
            .OrderByDescending(r => r.StartedAt)
            .Take(8)
            .ToListAsync();

        var flowIds = _recentRuns.Select(r => r.FlowId).Distinct();
        _flows = await db.Flows
            .Where(f => flowIds.Contains(f.Id))
            .ToDictionaryAsync(f => f.Id, f => f.Name);

        _lastRefresh = DateTimeOffset.Now;
    }

    private static string GetRunColor(FlowRunStatus s) => s switch
    {
        FlowRunStatus.Running   => "primary",
        FlowRunStatus.Paused    => "warning",
        FlowRunStatus.Completed => "success",
        FlowRunStatus.Failed    => "danger",
        FlowRunStatus.Cancelled => "secondary",
        _ => "secondary"
    };
}
