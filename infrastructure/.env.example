# =============================================================
# Nox Orchestration — Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================

# --- PostgreSQL (main DB) ---
POSTGRES_USER=nox
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=nox

# --- PostgreSQL (Orleans cluster store) ---
POSTGRES_ORLEANS_USER=nox
POSTGRES_ORLEANS_PASSWORD=change_me_strong_password_here
POSTGRES_ORLEANS_DB=nox_orleans

# --- Redis ---
REDIS_PASSWORD=change_me_strong_password_here

# --- Qdrant ---
QDRANT_API_KEY=change_me_strong_password_here

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_strong_password_here
# Client secret for nox-api (must match nox-realm.json)
KEYCLOAK_CLIENT_SECRET=nox-api-secret-change-me-in-production

# --- Seq (log aggregator) ---
# Hash generated with: echo -n "yourpassword" | sha256sum (Seq format)
SEQ_ADMIN_PASSWORD_HASH=

# --- LLM API Keys ---
ANTHROPIC_API_KEY=sk-ant-api03-replace-with-real-key
OPENAI_API_KEY=sk-replace-with-real-key
GOOGLE_API_KEY=replace-with-real-key

# --- App URLs (for CORS and SignalR) ---
NOX_API_URL=http://localhost:5000
NOX_DASHBOARD_URL=http://localhost:5050
